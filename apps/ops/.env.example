# Copy to apps/ops/.env  —  NEVER commit the real .env (it is gitignored).

# ── Server ──────────────────────────────────────────────────────────────────
OPS_PORT=4100

# Admin bearer token. ALL write endpoints and the dashboard require this.
# Generate a long random one, e.g.  openssl rand -hex 32
OPS_ADMIN_TOKEN=change-me-to-a-long-random-secret

# Bind address. Keep 127.0.0.1 for local-only operation (recommended on testnet).
# Set 0.0.0.0 only if you front it with a reverse proxy + TLS + auth.
OPS_HOST=127.0.0.1

# ── Chain ───────────────────────────────────────────────────────────────────
ARC_RPC_URL=https://rpc.testnet.arc.network

# Owner/deployer key used ONLY for owner-only on-chain actions (setJuror, setModeAStakeEnabled,
# setAttester). Must be the proxies' owner (the echo-deployer). Leave BLANK to run the dashboard
# in read-only mode (monitoring + off-chain flags still work, on-chain writes are disabled).
# This is a SECRET — it stays in .env and is never committed.
DEPLOYER_PRIVATE_KEY=

# ── Data ────────────────────────────────────────────────────────────────────
# Same Postgres the indexer uses — ops reads its tables (cursor/disputes/events) for monitoring
# and owns its own `ops_feature_flags` table for toggles.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/echo_indexer

# Indexer GraphQL endpoint (for a reachability ping on the status panel).
INDEXER_GRAPHQL_URL=http://127.0.0.1:4000/graphql

{
  "name": "@echo/ops",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Echo Protocol operator dashboard — monitoring, feature flags, and owner-only on-chain controls",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "totp:setup": "tsx src/setup-totp.ts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "postgres": "^3.4.0",
    "viem": "^2.0.0",
    "dotenv": "^16.4.0",
    "@echo/sdk": "workspace:*",
    "@echo/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^20.0.0"
  }

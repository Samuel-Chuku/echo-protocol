# Copy to apps/indexer/.env

# Arc testnet RPC (HTTP polling — robust vs. public WS).
ARC_RPC_URL=https://rpc.testnet.arc.network

# Self-hosted AgenticCommerce proxy (Path C). Node-side, so the plain (non-NEXT_PUBLIC) var works.
# Event ingestion watches MarketRegistry/EchoHook/DisputeResolver directly and is unaffected; this
# only fixes the resolver's on-demand getJob enrichment, which otherwise reads canonical (0x0747…).
ARC_AGENTIC_COMMERCE=0x1211eDC2E56D849c2d7a2E6EbeDeC6189835bF16

# Postgres connection string. Use the "Direct connection" (port 5432) from Supabase →
# Project Settings → Database → Connection string. Format:
#   postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# For local dev with Docker: postgres://postgres:postgres@localhost:5432/echo_indexer
DATABASE_URL=postgres://postgres:postgres@localhost:5432/echo_indexer

# Backfill start block = the earliest Echo deploy block on Arc testnet (don't scan from 0 — that's
# ~46M empty blocks). Bump it forward if you only care about recent activity.
START_BLOCK=46035076

# Ingestion tuning. Arc public RPC caps eth_getLogs ranges — keep BATCH_SIZE modest.
BATCH_SIZE=2000
POLL_INTERVAL_MS=4000

# GraphQL server.
PORT=4000

# ── SIWE / Sessions (Sign-In With Ethereum) ─────────────────────────────────
# Content-channel writes/reads are proven against a signed session instead of a claimed address.

# Chain the SIWE message must bind to. Arc testnet = 5042002. A signature scoped to another chain
# is rejected.
ARC_CHAIN_ID=5042002

# How long a proven session lasts before the user must re-sign (minutes). 1440 = 24h.
SESSION_TTL_MIN=1440

# Domain the SIWE message must bind to (EIP-4361). MUST equal the web app's HOST exactly (the client
# signs `window.location.host`). The app is served at app.echoprotocol.site, so it's that — NOT the
# apex echoprotocol.site (a mismatch rejects every sign-in with "domain mismatch"). Leave BLANK to
# accept any domain (fine on testnet).
#   e.g. SIWE_DOMAIN=app.echoprotocol.site
SIWE_DOMAIN=

# Rollout switch. false = backward-compatible (a present session is enforced, but unauthenticated
# legacy calls still work). true = a valid SIWE session is REQUIRED for every content write/read.
# Flip to true once the frontend sign-in flow is live for all wallets.
REQUIRE_AUTH=false

# ── Autonomous AI agent (#4) ────────────────────────────────────────────────
# The agent screens public previews and autonomously reveals/advances via a Circle Developer-
# Controlled Wallet on Arc, scoring with Claude. Everything below is OFF unless AGENT_ENABLED=true
# AND the Circle + Anthropic keys are set. Leave disabled until you've provisioned a DCW + funded it.
AGENT_ENABLED=false
# Dry-run: LLM screens + records decisions but performs NO on-chain actions. Test the brain + loop
# with only OPENROUTER_API_KEY + a local DB (no Circle keys / funded wallet). Flip off for the real run.
AGENT_DRY_RUN=false
AGENT_POLL_INTERVAL_MS=15000

# Circle Console → API key + registered Entity Secret (Developer-Controlled Wallets).
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Optional: reuse one wallet set for all requester DCWs. Created on first provision if blank.
CIRCLE_WALLET_SET_ID=

# LLM via OpenRouter (OpenAI-compatible). Screens previews + evaluates advancement guardrails.
# OPENROUTER_MODEL is any slug OpenRouter supports — e.g. anthropic/claude-haiku-4.5,
# anthropic/claude-sonnet-5, anthropic/claude-opus-4.8. Slugs get retired (claude-3.5-sonnet
# now 404s) — check https://openrouter.ai/api/v1/models if the agent loop logs OpenRouter 404.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

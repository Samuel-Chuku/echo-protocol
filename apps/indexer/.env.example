# Copy to apps/indexer/.env

# Arc testnet RPC (HTTP polling — robust vs. public WS).
ARC_RPC_URL=https://rpc.testnet.arc.network

# Self-hosted AgenticCommerce proxy (Path C). Node-side, so the plain (non-NEXT_PUBLIC) var works.
# Event ingestion watches MarketRegistry/EchoHook/DisputeResolver directly and is unaffected; this
# only fixes the resolver's on-demand getJob enrichment, which otherwise reads canonical (0x0747…).
ARC_AGENTIC_COMMERCE=0x1211eDC2E56D849c2d7a2E6EbeDeC6189835bF16

# Postgres connection string. Use the "Direct connection" (port 5432) from Supabase →
# Project Settings → Database → Connection string. Format:
#   postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# For local dev with Docker: postgres://postgres:postgres@localhost:5432/echo_indexer
DATABASE_URL=postgres://postgres:postgres@localhost:5432/echo_indexer

# Backfill start block = the earliest Echo deploy block on Arc testnet (don't scan from 0 — that's
# ~46M empty blocks). Bump it forward if you only care about recent activity.
START_BLOCK=46035076

# Ingestion tuning. Arc public RPC caps eth_getLogs ranges — keep BATCH_SIZE modest.
BATCH_SIZE=2000
POLL_INTERVAL_MS=4000

# GraphQL server.
PORT=4000

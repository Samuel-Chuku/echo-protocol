# Copy to apps/web/.env.local and fill in. All NEXT_PUBLIC_* are exposed to the browser.

# The app's own origin. This single project also serves the marketing surface (/site) on the bare
# domain; the marketing "Go to App" links and middleware apex-redirect target this. Set to the app
# subdomain in production; defaults to http://localhost:3000 in code for local dev.
NEXT_PUBLIC_APP_URL=https://app.echoprotocol.site

# Marketing origin — powers the app's "About Echo" link and footer back-link. Defaults to
# https://echoprotocol.site in code; only set this to override (e.g. a preview/staging URL).
NEXT_PUBLIC_MARKETING_URL=https://echoprotocol.site

# WalletConnect / mobile wallets in the RainbowKit modal (free id from https://cloud.reown.com).
# Injected wallets (Rabby / MetaMask / Browser) work without it; only WalletConnect needs a real id.
NEXT_PUBLIC_WC_PROJECT_ID=

# GraphQL indexer (apps/indexer). The worker browse + activity views read from here instead of
# looping raw RPC reads. Run `pnpm --filter @echo/indexer dev` to serve it locally.
NEXT_PUBLIC_INDEXER_URL=http://localhost:4000/graphql

# Operator feature flags published by apps/ops (GET /api/flags/public). Powers the maintenance
# banner + pause-market-creation + hide-reject gates. Fails open: if unset/unreachable the site
# behaves normally. Leave blank to disable flag-reading entirely.
NEXT_PUBLIC_OPS_FLAGS_URL=http://localhost:4100/api/flags/public

# Self-hosted AgenticCommerce proxy (Path C). MUST be the NEXT_PUBLIC_ form — the browser SDK calls
# AgenticCommerce directly (submit / getJob / rejectTierJob / requestRevision); without this it falls
# back to Circle's canonical instance (0x0747…) where EchoHook isn't whitelisted and those calls revert.
# Unset to return to canonical once Circle whitelists Echo.
NEXT_PUBLIC_ARC_AGENTIC_COMMERCE=0x1211eDC2E56D849c2d7a2E6EbeDeC6189835bF16

# --- Circle Modular Wallet (optional; see lib/circle.ts) ---
# From Circle Console → API & Client Keys → Modular Wallets. Circle supports Arc (chain code
# ARC-TESTNET, Wallets SCA). The Circle wallet appears in the connect modal once KEY + URL are set.
# CLIENT_URL is the shared modular-SDK endpoint, not a per-app value:
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl
# Chain slug appended to CLIENT_URL to target Arc. Defaults to 'arcTestnet' in code — only set this
# to override.
NEXT_PUBLIC_CIRCLE_CHAIN_SLUG=arcTestnet

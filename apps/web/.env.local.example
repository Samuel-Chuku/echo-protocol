# Copy to apps/web/.env.local and fill in. All NEXT_PUBLIC_* are exposed to the browser.

# WalletConnect / mobile wallets in the RainbowKit modal (free id from https://cloud.reown.com).
# Injected wallets (Rabby / MetaMask / Browser) work without it; only WalletConnect needs a real id.
NEXT_PUBLIC_WC_PROJECT_ID=

# GraphQL indexer (unused until the indexer ships; the console reads the chain directly for now).
NEXT_PUBLIC_INDEXER_URL=http://localhost:4000/graphql

# --- Circle Modular Wallet (optional; see lib/circle.ts) ---
# From Circle Console → API & Client Keys → Modular Wallets. Circle supports Arc (chain code
# ARC-TESTNET, Wallets SCA). The Circle wallet appears in the connect modal once KEY + URL are set.
# CLIENT_URL is the shared modular-SDK endpoint, not a per-app value:
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl
# Chain slug appended to CLIENT_URL to target Arc. Defaults to 'arcTestnet' in code — only set this
# to override.
NEXT_PUBLIC_CIRCLE_CHAIN_SLUG=arcTestnet

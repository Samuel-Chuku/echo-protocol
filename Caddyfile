# Caddy fronts the two backends with automatic HTTPS (Let's Encrypt).
# DOMAIN + ACME_EMAIL are injected by docker-compose.

{
	email {$ACME_EMAIL}
}

# Public GraphQL indexer — the web app reads from here.
api.{$DOMAIN} {
	reverse_proxy indexer:4000
}

# Operator dashboard. The TOTP login (+ session→IP-pinned tokens) guards the app itself, but this
# panel can hold the deployer key — so a network gate sits in FRONT of it as a second factor:
# HTTP Basic Auth. A visitor must clear basic_auth before they can even see the login page, let
# alone reach the admin API. Credentials come from the environment (OPS_BASICAUTH_USER / _HASH),
# injected by docker-compose so the bcrypt hash never lands in this committed file.
#
# Generate the hash once (choose your own password):
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-strong-password'
# then put OPS_BASICAUTH_USER + OPS_BASICAUTH_HASH in the VPS root .env (see .env.example).
#
# NOTE: `basic_auth` is the Caddy 2.8+ directive name; on older Caddy use `basicauth`.
# Alternatives if you outgrow this: IP allowlist (@allowed remote_ip …) or Cloudflare Access (SSO).
ops.{$DOMAIN} {
	# Public, unauthenticated — every site visitor's browser polls the maintenance flags from here
	# with NO credentials, so these two paths must bypass basic_auth. They expose no secrets.
	@public path /api/flags/public /api/health
	handle @public {
		reverse_proxy ops:4100
	}

	# Everything else — the dashboard UI, /api/login, and the whole admin/on-chain API — is gated.
	handle {
		basic_auth {
			{$OPS_BASICAUTH_USER} {$OPS_BASICAUTH_HASH}
		}
		reverse_proxy ops:4100
	}
}

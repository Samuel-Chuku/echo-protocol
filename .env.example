# Echo Protocol Environment Variables
# Copy this file to .env and fill in YOUR values
# NEVER commit .env — it is gitignored

# ═══════════════════════════════════════════════════════════
# ARC BLOCKCHAIN
# ═══════════════════════════════════════════════════════════

# Testnet RPC endpoint for Arc
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_CHAIN_ID=5042002

# Mainnet RPC (for when Arc Mainnet launches)
ARC_MAINNET_RPC_URL=https://rpc.arc.network
ARC_MAINNET_CHAIN_ID=<TBD>

# Arc Block Explorer
ARC_EXPLORER_URL=https://testnet.arcscan.app

# ═══════════════════════════════════════════════════════════
# CONTRACT ADDRESSES (Arc Testnet — verify live before use)
# ═══════════════════════════════════════════════════════════

# Arc Native Standards (pre-deployed by Circle)
ERC_8183_AGENTIC_COMMERCE=0x0747EEf0...4583
ERC_8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC_8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC_8004_VALIDATION_REGISTRY=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
ARC_USDC=0x36...0000

# Echo Contracts (deployed by us — fill after deployment)
MARKET_REGISTRY_ADDRESS=
ECHO_HOOK_ADDRESS=
PARTICIPATION_RECEIPT_ADDRESS=

# ═══════════════════════════════════════════════════════════
# CIRCLE DEVELOPER CONSOLE
# ═══════════════════════════════════════════════════════════

# Get from https://console.circle.com → API Keys
CIRCLE_API_KEY=

# Entity Secret for dev-controlled wallets
# Generate in Console → Developer-controlled wallets
CIRCLE_ENTITY_SECRET=

# ═══════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════

# PostgreSQL connection string for indexer
DATABASE_URL=postgresql://postgres:password@localhost:5432/echo_indexer

# ═══════════════════════════════════════════════════════════
# FRONTEND (apps/web)
# ═══════════════════════════════════════════════════════════

# Public (prefixed with NEXT_PUBLIC_ so Next.js includes in client bundle)
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# Contract addresses (Echo — fill after deployment)
NEXT_PUBLIC_MARKET_REGISTRY_ADDRESS=
NEXT_PUBLIC_ECHO_HOOK_ADDRESS=
NEXT_PUBLIC_PARTICIPATION_RECEIPT_ADDRESS=

# Wallet provider (Dynamic or Circle)
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
NEXT_PUBLIC_CIRCLE_WALLET=

# ═══════════════════════════════════════════════════════════
# BACKEND / INDEXER (apps/indexer)
# ═══════════════════════════════════════════════════════════

# Indexing
INDEXER_START_BLOCK=0                 # Block to start backfill from
INDEXER_POLL_INTERVAL_MS=3000         # How often to poll for new blocks
INDEXER_BATCH_SIZE=1000               # Events per batch

# Server
INDEXER_PORT=4000
INDEXER_NODE_ENV=development

# ═══════════════════════════════════════════════════════════
# IDENTITY (Phase 2 — World ID)
# ═══════════════════════════════════════════════════════════

WORLD_ID_APP_ID=
WORLD_ID_ACTION_ID=echo-participation

# ═══════════════════════════════════════════════════════════
# SERVER / HOSTING
# ═══════════════════════════════════════════════════════════

# Vercel (apps/web)
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Render / Railway / Fly.io (apps/indexer)
RENDER_SERVICE_ID=

# ═══════════════════════════════════════════════════════════
# TESTING
# ═══════════════════════════════════════════════════════════

# Testnet deployer wallet private key (for deployment scripts only)
# NEVER use a mainnet key here. This is for testnet only.
DEPLOYER_PRIVATE_KEY=

# Anvil / Hardhat fork URL (for local testing)
FORK_URL=https://rpc.testnet.arc.network
